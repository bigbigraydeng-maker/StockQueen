# StockQueen V1 - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
# Anon key for user auth (login). Find in Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# DeepSeek AI Configuration
# ============================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================
# Tiger Open API Configuration
# ============================================
TIGER_ACCESS_TOKEN=your-tiger-access-token
TIGER_TIGER_ID=your-tiger-id
TIGER_ACCOUNT=your-account-number
TIGER_BASE_URL=https://openapi.itiger.com

# ============================================
# Twilio Configuration (Emergency Notifications)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_FROM=+1234567890
TWILIO_PHONE_TO=+6491234567

# ============================================
# Application Settings
# ============================================
APP_ENV=development
APP_NAME=StockQueen
LOG_LEVEL=INFO
TIMEZONE=Pacific/Auckland

# ============================================
# Risk Management Settings (Hardcoded in code, reference only)
# ============================================
# MAX_POSITIONS=2
# RISK_PER_TRADE=0.10
# MAX_DRAWDOWN=0.15
# CONSECUTIVE_LOSS_LIMIT=2

# ============================================
# RSS Feed URLs
# ============================================
PR_NEWSWIRE_URL=https://www.prnewswire.com/rss/
FDA_URL=https://www.fda.gov/about-fda/contact-fda/rss-feeds

# ============================================
# OpenClaw Configuration (Notification Service)
# ============================================
# Webhook URL for OpenClaw notifications
# TODO: 待 Ray 确认 OpenClaw 推送方式
# 暂时使用占位符
OPENCLAW_WEBHOOK_URL=placeholder

# ============================================
# Feishu Notification Configuration
# ============================================
# Webhook URL for Feishu notifications (for webhook bot)
# Format: https://open.feishu.cn/open-apis/bot/v2/hook/{webhook_id}
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Feishu Open Platform App Credentials (for event subscription long connection)
# Get these from Feishu Open Platform: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-app-secret

# ============================================
# WebSocket Configuration (Real-time Market Data)
# ============================================
# Tiger Open API WebSocket URL
# Sandbox (Development): wss://openapi-sandbox.itiger.com:443/ws
# Production (Live Trading): wss://openapi.itiger.com:443/ws
TIGER_WS_URL=wss://openapi-sandbox.itiger.com:443/ws

# WebSocket Settings
WS_PING_INTERVAL=30
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=10

# ============================================
# OpenAI Configuration (Embedding + RAG Summary)
# ============================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# ============================================
# Security Configuration
# ============================================
# API Key for protecting admin/trigger endpoints
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your-admin-api-key

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://stockqueen-api.onrender.com,http://localhost:8001
